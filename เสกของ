-- ฟังก์ชัน Tool Giver
-- =========================
local function cloneToBackpack(tool)
    local ok, err = pcall(function()
        local clone = tool:Clone()
        clone.Parent = LocalPlayer:WaitForChild("Backpack")
    end)
    if not ok then
        warn("[ToolGiver] ไม่สามารถ clone ได้:", err)
    end
end

local function createToolBtn(tool)
    local btn = Instance.new("TextButton", ScrollFrame)
    btn.Size = UDim2.new(1, 0, 0, 34)
    btn.BackgroundColor3 = Color3.fromRGB(22, 22, 34)
    btn.Text = "🔧 " .. tool.Name
    btn.TextColor3 = Color3.fromRGB(220, 220, 220)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 12
    btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.ZIndex = 11
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.TextTruncate = Enum.TextTruncate.AtEnd
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    local pad = Instance.new("UIPadding", btn)
    pad.PaddingLeft = UDim.new(0, 8)

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = Color3.fromRGB(30, 30, 50)
        }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = Color3.fromRGB(22, 22, 34)
        }):Play()
    end)

    btn.MouseButton1Click:Connect(function()
        cloneToBackpack(tool)
        TweenService:Create(btn, TweenInfo.new(0.1), {
            BackgroundColor3 = Color3.fromRGB(0, 160, 80)
        }):Play()
        task.delay(0.3, function()
            if btn and btn.Parent then
                TweenService:Create(btn, TweenInfo.new(0.2), {
                    BackgroundColor3 = Color3.fromRGB(22, 22, 34)
                }):Play()
            end
        end)
    end)
end

local function updateList()
    for _, v in ipairs(ScrollFrame:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end

    local seen = {}
    for _, v in ipairs(game:GetDescendants()) do
        if v:IsA("Tool")
        and v.Parent
        and v.Parent.Parent ~= LocalPlayer then
            if not seen[v.Name] then
                seen[v.Name] = true
                createToolBtn(v)
            end
        end
    end

    local count = 0
    for _ in pairs(seen) do count = count + 1 end
    UpdateBtn.Text = string.format("🔄 อัปเดต (%d tool)", count)
    task.delay(1.5, function()
        if UpdateBtn and UpdateBtn.Parent then
            UpdateBtn.Text = "🔄 อัปเดตรายการ"
        end
    end)
end

UpdateBtn.MouseButton1Click:Connect(updateList)
task.defer(updateList)

print("✅ WackShop Tool Giver Loaded!")
